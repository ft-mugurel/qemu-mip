# Copy to .qemu-connect.local and edit. Loaded by CLI + MCP when env unset.
QEMU_CONNECT_ROOT=/absolute/path/to/qemu-connect
QEMU_CONNECT_GUEST=/absolute/path/to/your/kernel
# QEMU_CONNECT_PROMPT=$
# QEMU_CONNECT_PLUGIN=$HOME/.local/lib/qemu-connect/libqemu-connect.so
# QEMU_CONNECT_ISO=/absolute/path/to/kernel.iso
# QEMU_CONNECT_DISK=/absolute/path/to/disk.img
